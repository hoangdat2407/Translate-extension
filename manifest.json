{
  "manifest_version": 3,
  "name": "WordDeck Translator",
  "version": "1.0.28",
  "description": "Select text to translate with a floating icon, auto-save vocabulary cards, review flashcards, highlight saved words, and sync via Google Drive OAuth.",
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "clipboardRead",
    "alarms"
  ],
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "https://api.dictionaryapi.dev/*",
    "https://generativelanguage.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "WordDeck Translator",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon/image.png",
      "32": "icon/image.png",
      "48": "icon/image.png",
      "128": "icon/image.png"
    }
  },
  "icons": {
    "16": "icon/image.png",
    "32": "icon/image.png",
    "48": "icon/image.png",
    "128": "icon/image.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "icon/image.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}